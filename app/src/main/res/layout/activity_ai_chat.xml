<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- 主聊天区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#F5CB58"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <TextView
                android:id="@+id/btn_menu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="≡"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CookMate AI"
                    android:textSize="17sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="在线 · 随时为你服务"
                    android:textSize="11sp"
                    android:textColor="#B3FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="×"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:gravity="center" />
        </LinearLayout>

        <!-- 聊天区 -->
        <ScrollView
            android:id="@+id/scroll_chat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/chat_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- 输入区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:paddingHorizontal="12dp"
            android:elevation="3dp">

            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="输入食材名称或问题..."
                android:background="@drawable/edittext_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="2"
                android:inputType="text"
                android:imeOptions="actionSend"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/btn_send"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="→"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/circle_send_bg" />
        </LinearLayout>
    </LinearLayout>

    <!-- 侧边栏 -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <!-- 侧边栏头部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#F5CB58"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="历史对话"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_new_chat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="＋"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#E0A030" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sessions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>