<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CookMate">
        <activity
            android:name=".MainActivity"
            android:exported="false">
        </activity>
        <activity
            android:name=".ui.inventory.AddFoodActivity"
            android:exported="false" />
        <activity
            android:name=".ui.camera.CameraActivity"
            android:exported="false" />
        <activity
            android:name=".ui.recipe.RecipeDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.community.CreatePostActivity"
            android:exported="false" />
        <activity android:name=".network.ai.AIChatActivity" android:exported="false"/>
        <activity android:name=".network.ai.ChatHistoryActivity" android:exported="false"/>
        <activity
            android:name=".ui.user.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ui.user.RegisterActivity" android:exported="false" />
        <activity android:name=".ui.recipe.AddRecipeActivity" android:exported="false" />
        <activity android:name=".ui.community.CreatePostActivity" android:exported="false" />
    </application>

</manifest>